    "@types/node": "^20.11.0",
    "adm-zip": "^0.5.18",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.20.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "obsidian": "latest",
    "ts-jest": "^29.4.11",
    "tslib": "^2.6.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "pdfjs-dist": "^4.0.0"
  }
